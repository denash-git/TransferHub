# TransferHub — пример конфига инстанса
# Скопируй в instance.env и заполни свои значения
# instance.env никогда не попадает в git

# Домен и TLS
DOMAIN=2.dtopl.online
ADMIN_EMAIL=

# Учётные данные NaiveProxy
NAIVE_USERNAME=myuser
NAIVE_PASSWORD=

# Шаблон фейкового сайта: techvision | meridian | northcraft
FAKE_SITE_TEMPLATE=techvision

# BBR TCP оптимизация (true|false)
ENABLE_BBR=true

# Префикс speedtest-ссылок (генерируется автоматически при установке)
SPEEDTEST_PREFIX=

# Дата установки (проставляется автоматически)
INSTALL_TIMESTAMP=
